{
  "name": "bingo-mini-app",
  "version": "1.0.0",
  "description": "Telegram Bingo Mini App with Wallet System",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "check": "node check-setup.js",
    "setup-db": "node setup-database.js",
    "render-build": "npm install && cd client && npm install && npm run build",
    "render-start": "node server/index.js"
  },
  "dependencies": {
    "express": "^4.17.1",
    "socket.io": "^2.5.0",
    "mysql2": "^2.3.3",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "crypto": "^1.0.1",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^1.41.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}
